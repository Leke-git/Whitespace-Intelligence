# PLATFORM ENV VARS
# Set these in Vercel/Netlify dashboard

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=

# Security
WEBHOOK_SECRET=             # Secret shared with n8n
ADMIN_URL_TOKEN=            # Secret token for admin access (e.g. ?token=...)

# AUTOMATION SECRETS
# Set these in n8n "Secrets" node

SUPABASE_SERVICE_KEY=
GEMINI_API_KEY=
OWNER_EMAIL=

# GITHUB SECRETS
# Set these in GitHub Settings -> Secrets

ANTHROPIC_API_KEY=          # Anthropic API key for code review (from console.anthropic.com)
VERCEL_TOKEN=               # Vercel Personal Access Token (from vercel.com/account/tokens)
VERCEL_ORG_ID=              # Vercel Organization ID (from vercel.com/[org]/settings)
VERCEL_PROJECT_ID=          # Vercel Project ID (from vercel.com/[org]/[project]/settings)
N8N_BASE_URL=
N8N_API_KEY=
SUPABASE_DB_URL=            # Format: postgres://[user]:[password]@[host]:[port]/[db]
